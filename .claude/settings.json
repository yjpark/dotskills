{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "beans prime" }] }
    ],
    "PreCompact": [
      { "hooks": [{ "type": "command", "command": "beans prime" }] }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Plan mode exited. If this was a ctx-clarify session, do NOT save the plan. Otherwise, save the approved plan by invoking /ctx-plan now.'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(grep: *)",
      "Bash(beans list:*)",
      "Bash(beans show:*)"
    ]
  }
}
